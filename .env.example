# Brain 服务环境变量示例

# 服务配置
BRAIN_HOST=0.0.0.0
BRAIN_PORT=8088
BRAIN_DEBUG=false
ENVIRONMENT=production

# 服务发现配置
BRAIN_MACRO_SERVICE_URL=http://macro:8080
BRAIN_PORTFOLIO_SERVICE_URL=http://portfolio:8080
BRAIN_EXECUTION_SERVICE_URL=http://execution:8087
BRAIN_FLOWHUB_SERVICE_URL=http://flowhub:8080

# 调度器配置
BRAIN_SCHEDULER_ENABLED=true
BRAIN_SCHEDULER_TIMEZONE=Asia/Shanghai

# 共享基础设施配置
DATABASE_URL=postgresql://postgres:postgres@timescaledb:5432/stock_data
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_TIMEOUT=30
ECONDB_DATABASE_URL=postgresql://postgres:postgres@timescaledb:5432/stock_data
ECONDB_DB_POOL_SIZE=10
ECONDB_DB_MAX_OVERFLOW=10
ECONDB_DB_POOL_RECYCLE=1800
ECONDB_DB_POOL_TIMEOUT=30
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# Schema 运行时控制
DB_SCHEMA_ENFORCE=true
DB_SCHEMA_REQUIRED_VERSION=V001
DB_SCHEMA_EXIT_ON_FAILURE=true
DB_ALLOW_RUNTIME_DDL=false

# 监控配置
BRAIN_MONITORING_ENABLED=true
BRAIN_METRICS_PORT=9090

# 日志配置
BRAIN_LOG_LEVEL=INFO
BRAIN_LOG_FILE=logs/integration.log

# 鉴权配置
BRAIN_AUTH_JWT_SECRET=
BRAIN_AUTH_ADMIN_PASSWORD=
BRAIN_AUTH_REFRESH_COOKIE_NAME=autotm_refresh_token
BRAIN_AUTH_REFRESH_COOKIE_PATH=/api/v1/ui/auth
BRAIN_AUTH_REFRESH_COOKIE_SAMESITE=Lax
